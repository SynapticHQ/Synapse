{
  "name": "synapse",
  "version": "1.0.0",
  "description": "Multi-agent MCP orchestrator for Solana DeFi — routes tasks to specialized Claude agents",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "bun run --watch index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@solana/web3.js": "^1.98.0",
    "zod": "^4.3.6",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "bun-types": "latest"
  },
  "keywords": [
    "solana", "mcp", "multi-agent", "orchestrator", "claude",
    "defi", "autonomous", "ai-agent"
  ],
  "license": "MIT"
}


